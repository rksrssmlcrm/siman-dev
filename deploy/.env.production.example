# SimanDev — production environment variables
# Copy to deploy/.env on the server and fill in all values.
# NEVER commit deploy/.env to git.

# ── Domain & TLS ──────────────────────────────────────────────────────────────
# Public domain served by Caddy (must match DNS A-record pointing to VPS)
STAGING_DOMAIN=

# Email for Let's Encrypt certificate expiry notifications
ACME_EMAIL=

# ── Environment ───────────────────────────────────────────────────────────────
# production | staging
ENVIRONMENT=production

# Set to 1 on staging/pre-production to send X-Robots-Tag: noindex via Caddy
STAGING=1

# ── PostgreSQL (db service) ───────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=simandev

# Async SQLAlchemy URL — host must be the Compose service name "db"
# Format: postgresql+asyncpg://USER:PASSWORD@db:5432/DBNAME
DATABASE_URL=

# ── Backend security ──────────────────────────────────────────────────────────
# Random string, min 16 chars: openssl rand -hex 32
SECRET_KEY=

# Comma-separated allowed origins (must match STAGING_DOMAIN with https://)
# Example: https://simandev.ru
CORS_ORIGINS=

# ── Lead processing ───────────────────────────────────────────────────────────
LEAD_RETENTION_DAYS=180
RATE_LIMIT_LEADS=5/minute
PROJECT_NAME=SimanDev

# ── Lead notifications (optional) ───────────────────────────────────────────
# Set LEAD_NOTIFICATIONS=false to store leads in DB only (no Telegram/email).
# Otherwise configure Telegram and/or SMTP below.
LEAD_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email notifications (alternative or additional channel) ─────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=

# ── Admin panel (optional, disabled by default) ───────────────────────────────
ENABLE_ADMIN=false
# Generate hash: cd backend && uv run python -c "from app.services.admin import hash_password; print(hash_password('your-password'))"
ADMIN_PASSWORD_HASH=

# ── Frontend build args (inlined at Docker build time) ────────────────────────
# Must match STAGING_DOMAIN with https://
NEXT_PUBLIC_SITE_URL=

# Yandex Metrika counter ID (digits only); leave empty to disable
NEXT_PUBLIC_METRIKA_ID=

# ── NOT needed in production (Caddy routes /api/* directly) ───────────────────
# API_INTERNAL_URL=
