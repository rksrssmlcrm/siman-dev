# SimanDev — production Caddy config
# Environment variables (from deploy/.env):
#   STAGING_DOMAIN  — public domain, e.g. simandev.ru
#   ACME_EMAIL      — email for Let's Encrypt certificate notifications
#   STAGING         — set to 1 to add X-Robots-Tag: noindex (hide from search engines)

{
	email {$ACME_EMAIL}
}

{$STAGING_DOMAIN} {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' mc.yandex.ru mc.yandex.com; connect-src 'self' mc.yandex.ru mc.yandex.com; img-src 'self' data: blob: mc.yandex.ru; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	@staging expression {env.STAGING} == "1"
	header @staging X-Robots-Tag "noindex, nofollow"

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /_next/static/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy frontend:3000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
