# Environment: local | staging | production
ENVIRONMENT=

# Backend
DATABASE_URL=
SECRET_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ENABLE_ADMIN=false
PROJECT_NAME=SimanDev

# Email notifications
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS (comma-separated origins, no "*" in production)
CORS_ORIGINS=

# Leads processing
LEAD_RETENTION_DAYS=
RATE_LIMIT_LEADS=

# Frontend (public)
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_METRIKA_ID=

# Service-to-service URL for the FastAPI backend (used by Next.js rewrites).
#   Local dev without Docker: http://localhost:8000
#   Docker Compose:           http://backend:8000
#   Staging/production:       leave empty — Caddy routes /api/* before Next.js
API_INTERNAL_URL=
